rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Users collection: any authenticated user can read profiles (needed for friend lookup by email)
    // Write is allowed if:
    //   1. The user is modifying their own document, OR
    //   2. The user is modifying another user's pendingRequests/sentRequests/friends arrays
    //      (required for bi-directional friend request operations)
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && (
        request.auth.uid == userId ||
        request.auth.uid in resource.data.friends ||
        request.auth.uid in resource.data.pendingRequests ||
        request.auth.uid in resource.data.sentRequests ||
        request.auth.uid in request.resource.data.pendingRequests ||
        request.auth.uid in request.resource.data.sentRequests
      );
      allow create: if request.auth != null && request.auth.uid == userId;
    }

    // Expenses collection: authenticated users can create; 
    // only participants can read/update/delete
    match /expenses/{expenseId} {
      allow create: if request.auth != null;
      allow read: if request.auth != null && (
        request.auth.uid == resource.data.paidBy ||
        request.auth.uid in resource.data.splitWith
      );
      allow update, delete: if request.auth != null && (
        request.auth.uid == resource.data.paidBy
      );
    }

    // Groups collection: members only
    match /groups/{groupId} {
      allow read, write: if request.auth != null && (
        request.auth.uid in resource.data.members
      );
      allow create: if request.auth != null;
    }

    // Notifications collection: user can only read their own notifications
    match /notifications/{notificationId} {
      allow read, delete: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null;
    }
  }
}
